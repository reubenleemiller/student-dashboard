# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Supabase project URL (found in Settings → API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service-role key (secret — used by Netlify Functions ONLY, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cal.com webhook secret (set this in Cal.com Dashboard → Settings → Developer → Webhooks)
CAL_WEBHOOK_SECRET=your-webhook-secret-here
